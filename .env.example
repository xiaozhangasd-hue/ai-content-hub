# =====================================
# 南都AI 环境变量配置
# =====================================

# 数据库配置（SQLite本地数据库）
DATABASE_URL="file:./data.db"

# JWT认证密钥（请修改为随机字符串，至少32位）
JWT_SECRET="your-super-secret-jwt-key-change-this-to-random-string"

# =====================================
# AI服务配置（必填）
# =====================================

# AI服务提供商：deepseek | siliconflow | zhipu
AI_PROVIDER="deepseek"

# AI模型名称（可选，使用默认值即可）
AI_MODEL="deepseek-chat"

# DeepSeek配置（推荐，国内可直接访问）
# 官网：https://platform.deepseek.com/
# 价格：约1元/百万tokens
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# =====================================
# 图片生成配置
# =====================================

# 图片生成服务商：siliconflow | zhipu | dashscope
IMAGE_PROVIDER="siliconflow"

# 硅基流动配置（推荐，Kolors模型免费）
# 官网：https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY="sk-your-siliconflow-api-key"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"

# 智谱AI配置（备选）
# 官网：https://open.bigmodel.cn/
# ZHIPU_API_KEY="xxxxxxxxxxxxxxxx"

# 阿里云通义万象（备选）
# DASHSCOPE_API_KEY="sk-xxxxxxxxxxxxxxxx"

# =====================================
# 视频生成配置（可灵AI）
# =====================================

# 视频生成服务商：kling | runway | pika
VIDEO_PROVIDER="kling"

# 可灵AI配置（快手，推荐）
# 官网：https://klingai.com/cn/dev
# 支持功能：视频生成、数字人、对口型
# 
# 使用步骤：
# 1. 访问 https://klingai.com/cn/dev 注册账号
# 2. 购买资源包（有试用额度）
# 3. 在控制台创建API Key
# 4. 将Access Key和Secret Key填入下方
KLING_ACCESS_KEY="your-access-key"
KLING_SECRET_KEY="your-secret-key"
KLING_BASE_URL="https://api-beijing.klingai.com"

# =====================================
# 腾讯云验证码配置（可选，防刷保护）
# =====================================

# 腾讯云天御验证码
# 官网：https://cloud.tencent.com/product/captcha
# 
# 使用步骤：
# 1. 访问腾讯云控制台：https://console.cloud.tencent.com/captcha
# 2. 创建验证应用，获取AppId和AppSecretKey
# 3. 将配置填入下方
#
# TENCENT_CAPTCHA_APP_ID="你的验证码AppId"
# TENCENT_CAPTCHA_APP_SECRET="你的验证码AppSecretKey"

# =====================================
# 对象存储配置（可选，用于存储生成的文件）
# =====================================

# AWS S3 或兼容服务（如阿里云OSS、腾讯云COS）
# OSS_ACCESS_KEY_ID=""
# OSS_ACCESS_KEY_SECRET=""
# OSS_BUCKET=""
# OSS_REGION=""
# OSS_ENDPOINT=""

# =====================================
# 应用配置
# =====================================

# 运行环境
NODE_ENV="production"

# 服务端口
PORT="5000"

# 应用名称和URL
NEXT_PUBLIC_APP_NAME="南都AI"
NEXT_PUBLIC_APP_URL="http://localhost:5000"

# =====================================
# 支付配置（支付宝 / 微信支付）
# =====================================

# 公共回调地址（示例）
# 建议生产环境为 https://你的域名/api/payments/callback/xxx
ALIPAY_NOTIFY_URL="http://localhost:5000/api/payments/callback/alipay"

# 支付宝
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# 微信支付V3
WECHAT_PAY_APP_ID=""
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_PRIVATE_KEY=""
WECHAT_PAY_CERT_SERIAL_NO=""
